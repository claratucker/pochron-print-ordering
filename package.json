{
  "name": "pochron-print-ordering-backend",
  "version": "1.0.0",
  "description": "Phase 1 backend for Pochron Studios online print ordering. Serves the photo-upload mockup: server-authoritative pricing, direct-to-cloud uploads, order + proofing lifecycle, Stripe auth/capture seams, transactional email, admin pricing page.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/db/seed.js",
    "smoke": "node scripts/smoke.js && node scripts/smoke-large.js",
    "smoke:large": "node scripts/smoke-large.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:stripe": "PAYMENT_DRIVER=stripe vitest run tests/payments-stripe.test.js",
    "test:all": "vitest run && npm run smoke",
    "backup": "node scripts/backup.js",
    "check:storage": "node scripts/check-storage.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "bcryptjs": "^2.4.3",
    "sharp": "^0.33.5",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}