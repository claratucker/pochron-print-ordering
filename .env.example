# ─── Pochron Studios print-ordering backend — configuration ───────────────
# Copy to `.env` and fill in for your environment. Everything has a safe local
# default so the app boots and the whole order loop runs with mock adapters.

# Server
PORT=4000
NODE_ENV=development
# Comma-separated origins allowed to call the API (the order app + the mockup).
# In production: https://order.pochronstudios.com
CORS_ORIGINS=http://localhost:4000,http://localhost:5173,http://127.0.0.1:5500

# Signing secret for the guest-draft cookie and admin session. CHANGE THIS.
APP_SECRET=dev-only-change-me

# ─── Storage adapter ──────────────────────────────────────────────────────
# local  = files land on disk under ./data/uploads (dev only)
# s3     = presigned direct-to-cloud multipart, S3-compatible (production)
STORAGE_DRIVER=local
# For STORAGE_DRIVER=s3. Works with AWS S3 or any S3-compatible store.
# AWS_REGION=us-east-1            # for Cloudflare R2 use: auto
# S3_BUCKET=pochron-originals
# S3_CDN_BASE=https://cdn.pochronstudios.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# --- Cloudflare R2 (recommended: zero egress, so re-downloading GB originals is free) ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
# Presigned part URLs need headroom for slow links on multi-GB uploads.
PRESIGN_TTL_SECONDS=3600

# Upload limits (re-enforced server-side)
MAX_FILES=12
MAX_BYTES=21474836480          # 20 GB — high-end scans are routinely multi-GB
UPLOAD_PART_SIZE=67108864      # 64 MB chunks (×10,000 parts ≈ 640 GB ceiling)
UPLOAD_MAX_PARTS=10000
# Files at/above this skip in-request processing: header-only metadata + a
# background malware scan, so a multi-GB upload never blocks the app server.
INLINE_PROCESS_MAX_BYTES=268435456   # 256 MB
HEADER_READ_BYTES=8388608            # 8 MB read for dimensions on big files
ACCEPTED_MIME=image/jpeg,image/tiff,image/png,image/vnd.adobe.photoshop,application/x-photoshop,image/x-photoshop

# ─── Payment adapter (Stripe) ─────────────────────────────────────────────
# mock   = no real charges, deterministic ids (dev)
# stripe = real authorize-at-submit / capture-on-approval
PAYMENT_DRIVER=mock
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...   # safe to expose; sent to the browser
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email adapter ────────────────────────────────────────────────────────
# console = prints emails to the server log (dev)
# smtp    = real SMTP (e.g. SES SMTP creds)
EMAIL_DRIVER=console
EMAIL_FROM="Pochron Studios <info@pochronstudios.com>"
STUDIO_CONTACT_URL=https://www.pochronstudios.com/contactus
# For EMAIL_DRIVER=smtp :
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Tax adapter ──────────────────────────────────────────────────────────
# none  = returns 0 (mockup defers tax to the address; wire a provider for prod)
# flat  = TAX_FLAT_RATE applied to (prints + shipping)
TAX_DRIVER=none
TAX_FLAT_RATE=0.08875          # example: NYC combined

# ─── Studio + admin access ────────────────────────────────────────────────
# Password for the /studio proofing queue API and the /admin pricing page.
# Store a bcrypt hash in production (npm run hash -- 'yourpassword').
STUDIO_PASSWORD=studio-dev
ADMIN_PASSWORD=admin-dev

# ─── Retention (draft + abandoned-upload purge, §5/§14) ───────────────────
DRAFT_TTL_DAYS=30

# Fulfillment / packaging (§10)
# Normal orders ship with the studio's return address.
STUDIO_RETURN_ADDRESS="Pochron Studios\n117 9th Street, Rm #210\nBrooklyn, NY 11215"
# White-label orders ship from the same place but under the CUSTOMER's own
# business name (collected at checkout), with no studio branding or inserts.
DROP_ADDRESS="117 9th Street, Rm #210\nBrooklyn, NY 11215"

# Email verification (§8 layer 3): none | kickbox | zerobounce
# Catches addresses that pass a format check but don't actually exist.
EMAIL_VERIFY_DRIVER=none
# EMAIL_VERIFY_API_KEY=
